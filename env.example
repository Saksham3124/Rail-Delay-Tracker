# -----------------------------------------------
# Rail Delay Tracker — Environment Variables
# -----------------------------------------------
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to GitHub.

# PostgreSQL connection string (optional)
# If not set, the app will fall back to CSV-only storage
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DB_URL=postgresql://your_user:your_password@localhost:5432/rail_delay_db
